import os
import json
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

from sklearn.preprocessing import StandardScaler, LabelEncoder
from sklearn.model_selection import StratifiedKFold
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import (
    accuracy_score, precision_score, recall_score, f1_score,
    confusion_matrix
)

from web3 import Web3

SEED = 42
np.random.seed(SEED)

# =====================================================
# GLOBAL GRAPH STYLE (AS REQUESTED)
# =====================================================
plt.rcParams["font.family"] = "Times New Roman"
plt.rcParams["font.weight"] = "bold"
plt.rcParams["axes.titleweight"] = "bold"
plt.rcParams["axes.labelweight"] = "bold"

FIGSIZE = (10, 6)
TITLE_SIZE = 22
LABEL_SIZE = 20
TICK_SIZE = 18
LEGEND_SIZE = 16

# =====================================================
# 1. FOLDER SETUP
# =====================================================
BASE_DIR = "final_correct_results"
METRIC_DIR = os.path.join(BASE_DIR, "metrics")
GRAPH_DIR = os.path.join(BASE_DIR, "graphs")

os.makedirs(METRIC_DIR, exist_ok=True)
os.makedirs(GRAPH_DIR, exist_ok=True)

# =====================================================
# 2. LOAD DATA
# =====================================================
df = pd.read_csv("blockchain_wsn_dataset.csv")
df = df.dropna().reset_index(drop=True)

# =====================================================
# 3. ENCODE NODE TYPE
# =====================================================
df["node_type"] = LabelEncoder().fit_transform(df["node_type"])

# =====================================================
# 4. CREATE RISK LABEL
# =====================================================
q_energy = df["energy_level"].quantile([0.25, 0.4])
q_thr = df["throughput"].quantile(0.25)

def risk_label(row):
    if row["energy_level"] < q_energy[0.25] and row["throughput"] < q_thr:
        return 2
    elif row["energy_level"] < q_energy[0.4]:
        return 1
    else:
        return 0

df["risk_level"] = df.apply(risk_label, axis=1)

# =====================================================
# 5. FEATURES
# =====================================================
features = [
    "node_type",
    "energy_level",
    "residual_energy",
    "transmission_count",
    "pdr",
    "ber",
    "throughput",
    "end_to_end_delay"
]

X = df[features]
y = df["risk_level"]

scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

# =====================================================
# 6. STRATIFIED K-FOLD
# =====================================================
skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=SEED)

accs, precs, recs, f1s = [], [], [], []
cm_total = np.zeros((3, 3))
oof_probs = np.zeros((len(y), 3))

# =====================================================
# 7. MODEL
# =====================================================
model = RandomForestClassifier(
    n_estimators=250,
    max_depth=16,
    min_samples_leaf=4,
    random_state=SEED,
    n_jobs=-1
)

# =====================================================
# 8. TRAIN & EVALUATE
# =====================================================
for train_idx, test_idx in skf.split(X_scaled, y):
    X_train, X_test = X_scaled[train_idx], X_scaled[test_idx]
    y_train, y_test = y.iloc[train_idx], y.iloc[test_idx]

    model.fit(X_train, y_train)
    y_pred = model.predict(X_test)
    y_prob = model.predict_proba(X_test)

    accs.append(accuracy_score(y_test, y_pred))
    precs.append(precision_score(y_test, y_pred, average="weighted"))
    recs.append(recall_score(y_test, y_pred, average="weighted"))
    f1s.append(f1_score(y_test, y_pred, average="weighted"))

    cm_total += confusion_matrix(y_test, y_pred, labels=[0,1,2])
    oof_probs[test_idx] = y_prob

# =====================================================
# 9. FINAL METRICS
# =====================================================
acc = np.mean(accs)
prec = np.mean(precs)
rec = np.mean(recs)
f1 = np.mean(f1s)

with open(os.path.join(METRIC_DIR, "metrics.txt"), "w") as f:
    f.write(f"Accuracy  : {acc:.4f}\n")
    f.write(f"Precision : {prec:.4f}\n")
    f.write(f"Recall    : {rec:.4f}\n")
    f.write(f"F1-score  : {f1:.4f}\n")

# =====================================================
# 10. CONFUSION MATRIX (STYLE UPDATED)
# =====================================================
plt.figure(figsize=FIGSIZE)
sns.heatmap(
    cm_total.astype(int),
    annot=True,
    fmt="d",
    cmap="Blues",
    cbar=False,
    xticklabels=["Normal","Suspicious","Malicious"],
    yticklabels=["Normal","Suspicious","Malicious"],
    annot_kws={"size": TICK_SIZE, "weight": "bold"}
)

plt.title("Risk Level Confusion Matrix", fontsize=TITLE_SIZE)
plt.xlabel("Predicted Label", fontsize=LABEL_SIZE)
plt.ylabel("True Label", fontsize=LABEL_SIZE)
plt.xticks(fontsize=TICK_SIZE, fontweight="bold")
plt.yticks(fontsize=TICK_SIZE, fontweight="bold")
plt.tight_layout()
plt.savefig(os.path.join(GRAPH_DIR, "confusion_matrix.png"), dpi=300)
plt.close()

# =====================================================
# 11. FEATURE IMPORTANCE (STYLE UPDATED)
# =====================================================
importances = model.feature_importances_
idx = np.argsort(importances)[::-1]

plt.figure(figsize=FIGSIZE)
plt.bar([features[i] for i in idx], importances[idx], color="#1f77b4")

plt.title("Feature Importance (WSN Risk Detection)", fontsize=TITLE_SIZE)
plt.xlabel("Feature", fontsize=LABEL_SIZE)
plt.ylabel("Importance Score", fontsize=LABEL_SIZE)
plt.xticks(rotation=30, fontsize=TICK_SIZE, fontweight="bold")
plt.yticks(fontsize=TICK_SIZE, fontweight="bold")
plt.tight_layout()
plt.savefig(os.path.join(GRAPH_DIR, "feature_importance.png"), dpi=300)
plt.close()

# =====================================================
# 12. THRESHOLD-BASED WSN DECISION
# =====================================================
THRESHOLD = 0.6
malicious_probs = oof_probs[:, 2]
detected_nodes = np.where(malicious_probs >= THRESHOLD)[0] + 1
print("🚨 AI Detected Malicious Nodes:", detected_nodes.tolist())

# =====================================================
# 13. BLOCKCHAIN CONNECTION
# =====================================================
ganache_url = "http://127.0.0.1:7545"
web3 = Web3(Web3.HTTPProvider(ganache_url))
assert web3.is_connected(), "Web3 not connected"

with open("abi.json", "r") as f:
    abi = json.load(f)

contract_address = Web3.to_checksum_address(
    "0x90869D7156C3EB8a33a845beBA533520BB10c202"
)

contract = web3.eth.contract(address=contract_address, abi=abi)

account = Web3.to_checksum_address(
    "0x4C83FA05F26722e8A548CfbACbfa98c048ca6643"
)

private_key = "0xf9295805acd28e21603d9ce89eeec79ce3929d85c89b24041ac69cae691fc48e"

def build_tx():
    return {
        "from": account,
        "nonce": web3.eth.get_transaction_count(account),
        "gas": 3000000,
        "gasPrice": web3.to_wei("20", "gwei")
    }

# =====================================================
# 14. SMART CONTRACT CALL
# =====================================================
def mark_node_malicious(node_id):
    tx = contract.functions.markNodeMalicious(node_id).build_transaction(build_tx())
    signed = web3.eth.account.sign_transaction(tx, private_key)
    tx_hash = web3.eth.send_raw_transaction(signed.raw_transaction)
    receipt = web3.eth.wait_for_transaction_receipt(tx_hash)
    print(f"⛓️ Node {node_id} marked malicious | TX:", receipt.transactionHash.hex())

# =====================================================
# 15. AI → BLOCKCHAIN AUTOMATION
# =====================================================
for node_id in detected_nodes:
    mark_node_malicious(int(node_id))

print("\n✅ FULL AI + WSN + BLOCKCHAIN WORKFLOW COMPLETED")
print("📂 Results saved in:", os.path.abspath(BASE_DIR))
